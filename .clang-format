---
Language: Cpp
BasedOnStyle: Microsoft

# Tabs instead of spaces
UseTab: Always

# Access modifiers (public/private) at class indent level
AccessModifierOffset: -4

# Allman braces with indented case blocks
BreakBeforeBraces: Allman
IndentCaseBlocks: true

# No line length limit - avoid rewrapping existing long lines
ColumnLimit: 0

# Preserve double blank lines between sections
MaxEmptyLinesToKeep: 2

# Short forms - only collapse inline functions (in headers)
AllowShortBlocksOnASingleLine: Empty
AllowShortFunctionsOnASingleLine: InlineOnly

# Leave trailing comments where they are
AlignTrailingComments:
  Kind: Leave
  OverEmptyLines: 0

# Brace initializer lists - preserve spaces: { 1, 2, 3 }
Cpp11BracedListStyle: false

# Preserve existing include order
SortIncludes: Never

# Constructor initializers - colon at end of decl line, then break
BreakConstructorInitializers: AfterColon

# Binary operators wrap with operator at start of continuation line
BreakBeforeBinaryOperators: NonAssignment

## Naming conventions (documentation only - not enforced by clang-format)
#
# Classes/Structs/Enums: BMC_PascalCase / BME_UPPER_CASE
# Methods:              PascalCase
# Member variables:     m_snake_case
# Local variables:      snake_case
# Parameters:           _underscore_prefix
# Constants/arrays:     c_snake_case
